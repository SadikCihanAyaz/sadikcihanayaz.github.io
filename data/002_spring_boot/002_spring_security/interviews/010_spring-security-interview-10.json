      "id": "i10-q10",
      "type": "code",
      "question": "MockMvc ile 3 test yaz: (1) anonymous /admin -> 401 veya 403, (2) USER role /admin -> 403, (3) ADMIN role /admin -> 200.",
      "starterCode": "class SecurityTests {\n    // TODO\n}",
      "answerCode": "@SpringBootTest\n@AutoConfigureMockMvc\nclass SecurityTests {\n\n    @Autowired MockMvc mockMvc;\n\n    @Test\n    void admin_anonymous_shouldBeDenied() throws Exception {\n        mockMvc.perform(get(\"/admin/panel\"))\n            .andExpect(status().isUnauthorized());\n    }\n\n    @Test\n    @WithMockUser(username = \"u\", roles = {\"USER\"})\n    void admin_userRole_shouldBeForbidden() throws Exception {\n        mockMvc.perform(get(\"/admin/panel\"))\n            .andExpect(status().isForbidden());\n    }\n\n    @Test\n    @WithMockUser(username = \"a\", roles = {\"ADMIN\"})\n    void admin_adminRole_shouldPass() throws Exception {\n        mockMvc.perform(get(\"/admin/panel\"))\n            .andExpect(status().isOk());\n    }\n}",
